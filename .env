# AcademyPro API — Environment Variables
# cp .env.example .env  and fill in values

# ── App ──────────────────────────────────────────────────────────────────────
PROJECT_NAME="AcademyPro API"
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# ── Security ─────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 h
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ─────────────────────────────────────────────────────────────────
#postgresql://postgres.nlzyqywkjwcilqymbmzz:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres
#postgresql+asyncpg://postgres:uOf4oWp3g0SqlqaG@db.nlzyqywkjwcilqymbmzz.supabase.co:5432/postgres
#postgresql+asyncpg://postgres:postgres@db:5432/academypro
DATABASE_URL=postgresql+asyncpg://postgres.nlzyqywkjwcilqymbmzz:uOf4oWp3g0SqlqaG@aws-1-eu-north-1.pooler.supabase.com:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://app.academypro.io"]

# ── M-Pesa (Safaricom Daraja) ─────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.academypro.io/v1/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox        # sandbox | production

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@academypro.io

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=academypro-uploads
AWS_S3_REGION=af-south-1
CDN_BASE_URL=https://cdn.academypro.io
